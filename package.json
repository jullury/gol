{
  "name": "gol",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install",
    "eas:build:dev": "eas build --platform android --profile development --local",
    "eas:build:prod": "eas build --platform android --profile production --local"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@react-navigation/drawer": "^7.10.2",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "expo": "~54.0.33",
    "expo-font": "~14.0.11",
    "expo-image-picker": "^55.0.20",
    "expo-splash-screen": "^56.0.9",
    "expo-sqlite": "^55.0.16",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/react": "~19.1.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eas-cli": "^14.0.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.2.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "lefthook": "^1.11.0",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
